# Copy this file to .env and set values for your environment.
# Do NOT commit .env to source control.

# OpenAI API key for standard OpenAI usage.
OPENAI_API_KEY=

# Azure OpenAI configuration (use instead of OPENAI_API_KEY if using Azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-10-01

# Vite frontend variables (used by the client app)
VITE_AZURE_OPENAI_DEPLOYMENT_NAME=
VITE_OPENAI_API_BASE_URL=
